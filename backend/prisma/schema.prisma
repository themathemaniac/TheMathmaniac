datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String               @id @default(uuid())
  name                String
  email               String?              @unique
  phoneNumber         String?
  pushToken           String?
  googleId            String?
  firstLogin          Boolean              @default(true)
  role                String               @default("STUDENT")
  stream              String?
  class               String?
  faculty             String?
  school              String?
  subjects            String?
  purchases           Purchase[]
  lectureProgress     LectureProgress[]
  results             Result[]
  notifications       Notification[]
  attendance          Attendance[]
  feePayments         FeePayment[]
  teacherSchedules    TeacherSchedule[]
  teacherLocationLogs TeacherLocationLog[]
  teacherAttendances  TeacherAttendance[]
  courseTeachers      CourseTeacher[]
  adminShifts         AdminShift[]
  adminAttendances    AdminAttendance[]
  adminWeeklyPatterns AdminWeeklyPattern[]
  branchSwapRequests  AdminBranchSwapRequest[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([email])
}

model CourseCategory {
  id      String   @id @default(uuid())
  name    String
  slug    String   @unique
  courses Course[]
}

model Course {
  id               String          @id @default(uuid())
  title            String
  description      String
  thumbnailUrl     String
  price            Int
  categoryId       String
  category         CourseCategory  @relation(fields: [categoryId], references: [id])
  instructorName   String?
  learningOutcomes String
  timeSlots        String?         @default("[]")
  branch           String          @default("Sodepur")
  targetClass      String?
  published        Boolean         @default(false)
  isBundle         Boolean         @default(false)
  lectures         Lecture[]
  purchases        Purchase[]
  tests            Test[]
  studyMaterials   StudyMaterial[]
  teachers         CourseTeacher[]
  bundleItems      BundleItem[]    @relation("BundleToItem")
  partOfBundles    BundleItem[]    @relation("ItemToBundle")
  announcements    Announcement[]
  feePayments      FeePayment[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model BundleItem {
  id        String   @id @default(uuid())
  bundleId  String
  courseId  String
  createdAt DateTime @default(now())

  bundle Course @relation("BundleToItem", fields: [bundleId], references: [id], onDelete: Cascade)
  course Course @relation("ItemToBundle", fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([bundleId, courseId])
}

model Lecture {
  id              String            @id @default(uuid())
  courseId        String
  course          Course            @relation(fields: [courseId], references: [id])
  title           String
  description     String
  videoUrl        String
  duration        Int
  sortOrder       Int
  notesUrl        String?
  lectureProgress LectureProgress[]

  @@index([courseId])
}

model LectureProgress {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  lectureId    String
  lecture      Lecture  @relation(fields: [lectureId], references: [id])
  lastPosition Int      @default(0)
  completed    Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  @@unique([userId, lectureId])
  @@index([userId])
  @@index([lectureId])
}

model Purchase {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  courseId          String
  course            Course   @relation(fields: [courseId], references: [id])
  amount            Int
  status            String
  razorpayOrderId   String   @unique
  razorpayPaymentId String?
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([courseId])
}

model Test {
  id         String     @id @default(uuid())
  courseId   String?
  course     Course?    @relation(fields: [courseId], references: [id])
  title      String
  duration   Int
  totalMarks Int
  published  Boolean    @default(false)
  questions  Question[]
  results    Result[]
  pdfUrl     String?
  pdfSize    Int?
  pdfName    String?
  pdfData    Bytes?

  @@index([courseId])
}

model Question {
  id              String           @id @default(uuid())
  testId          String
  test            Test             @relation(fields: [testId], references: [id])
  text            String
  type            String
  numericalAnswer String?
  marks           Int
  explanation     String
  options         QuestionOption[]

  @@index([testId])
}

model QuestionOption {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  text       String
  isCorrect  Boolean

  @@index([questionId])
}

model Result {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  testId         String
  test           Test     @relation(fields: [testId], references: [id])
  score          Int
  accuracy       Float
  answersPayload String
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([testId])
}

model StudyMaterial {
  id        String   @id @default(uuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  title     String
  type      String
  fileUrl   String
  fileSize  Int
  fileData  Bytes?
  createdAt DateTime @default(now())

  @@index([courseId])
}

model Announcement {
  id         String   @id @default(uuid())
  title      String
  content    String
  courseId   String?
  course     Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  authorName String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userId    String
  actorId   String
  details   String
  createdAt DateTime @default(now())
}

model Attendance {
  id         String   @id @default(uuid())
  date       String // Format: YYYY-MM-DD
  status     String // "PRESENT", "ABSENT", "CANCELLED", "HOLIDAY"
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId   String?  // Made optional for backwards compatibility but should be used going forward
  recordedBy String // Teacher/Admin ID who recorded it
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, courseId, date])
  @@index([userId])
  @@index([date])
  @@index([courseId])
}

model FeePayment {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId          String?
  course            Course?   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  month             String // Format: YYYY-MM
  amount            Int // Base fee in Paisa
  fine              Int // Fine in Paisa
  totalAmount       Int // amount + fine in Paisa
  status            String // "PENDING", "SUCCESS", "FAILED", "PENDING_VERIFICATION"
  paymentMode       String?   // "ONLINE_UPI", "OFFLINE_CASH", "OFFLINE_CHEQUE"
  transactionNote   String?
  razorpayOrderId   String?   @unique
  razorpayPaymentId String?
  paidAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([courseId])
}

model TeacherSchedule {
  id                  String               @id @default(uuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  title               String // e.g. "Mathematics batch A"
  campus              String               @default("Campus A") // Identifier for the institute branch
  class               String? // e.g. "Class 11"
  subject             String? // e.g. "Mathematics"
  date                String // Format: YYYY-MM-DD
  startTime           String // Format: HH:MM
  endTime             String // Format: HH:MM
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teacherLocationLogs TeacherLocationLog[]
  teacherAttendances  TeacherAttendance[]

  @@index([userId])
}

model TeacherLocationLog {
  id         String          @id @default(uuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleId String
  schedule   TeacherSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  latitude   Float
  longitude  Float
  distance   Float // distance from institute in meters
  isInside   Boolean // inside 20m radius
  timestamp  DateTime        @default(now())

  @@index([userId])
  @@index([scheduleId])
}

model TeacherAttendance {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleId    String
  schedule      TeacherSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  date          String // Format: YYYY-MM-DD
  status        String // "PRESENT", "PARTIAL", "ABSENT"
  presenceRatio Float // fraction of inside pings vs total pings
  totalPings    Int
  insidePings   Int
  loginTime     DateTime?
  logoutTime    DateTime?
  teachingHours Float?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
  @@index([scheduleId])
}

model DailyReport {
  id        String   @id @default(uuid())
  title     String
  date      String   @unique // Format: YYYY-MM-DD
  pdfUrl    String // Relative URL, e.g. "/uploads/reports/attendance-2026-06-22.pdf"
  createdAt DateTime @default(now())
}

model CourseTeacher {
  id        String   @id @default(uuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
}

model AdminShift {
  id               String            @id @default(uuid())
  adminId          String
  admin            User              @relation(fields: [adminId], references: [id], onDelete: Cascade)
  branch           String            // e.g. "Sodepur", "Belgharia"
  date             String            // YYYY-MM-DD format
  startTime        String?           // hh:mm AM/PM
  endTime          String?           // hh:mm AM/PM
  type             String            @default("BRANCH_DUTY") // "BRANCH_DUTY" | "FIELD_PROMOTION"
  attendances      AdminAttendance[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([adminId])
}

model AdminAttendance {
  id             String      @id @default(uuid())
  adminId        String
  admin          User        @relation(fields: [adminId], references: [id], onDelete: Cascade)
  shiftId        String
  shift          AdminShift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  loginTime      DateTime    @default(now())
  logoutTime     DateTime?
  workingHours   Float?
  checkInLat     Float?
  checkInLng     Float?
  checkOutLat    Float?
  checkOutLng    Float?
  locationName   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([adminId])
  @@index([shiftId])
}

model AdminWeeklyPattern {
  id        String   @id @default(uuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  dayOfWeek Int      // 0 (Sunday) to 6 (Saturday)
  branch    String   // e.g. "Madhyamgram", "Sodepur"
  startTime String   // "hh:mm AM/PM"
  endTime   String   // "hh:mm AM/PM"
  type      String   @default("BRANCH_DUTY") // "BRANCH_DUTY" | "FIELD_PROMOTION"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([adminId, dayOfWeek])
  @@index([adminId])
}

model Holiday {
  id        String   @id @default(uuid())
  date      String   @unique // YYYY-MM-DD
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminBranchSwapRequest {
  id              String   @id @default(uuid())
  adminId         String
  admin           User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  date            String   // YYYY-MM-DD
  requestedBranch String
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([adminId, date])
  @@index([adminId])
}

model School {
  id        String   @id @default(uuid())
  name      String   @unique
  aliases   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
